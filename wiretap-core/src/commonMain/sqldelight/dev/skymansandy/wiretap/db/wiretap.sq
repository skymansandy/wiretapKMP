CREATE TABLE IF NOT EXISTS NetworkLogEntity (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    url TEXT NOT NULL,
    method TEXT NOT NULL,
    request_headers TEXT NOT NULL DEFAULT "",
    request_body TEXT,
    response_code INTEGER NOT NULL,
    response_headers TEXT NOT NULL DEFAULT "",
    response_body TEXT,
    duration_ms INTEGER NOT NULL,
    source TEXT NOT NULL DEFAULT "Network",
    timestamp INTEGER NOT NULL,
    matched_rule_id INTEGER,
    protocol TEXT,
    remote_address TEXT,
    tls_protocol TEXT,
    cipher_suite TEXT,
    certificate_cn TEXT,
    issuer_cn TEXT,
    certificate_expiry TEXT
);

CREATE INDEX IF NOT EXISTS idx_network_log_timestamp ON NetworkLogEntity (timestamp);

CREATE TABLE IF NOT EXISTS RuleEntity (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    method TEXT NOT NULL DEFAULT "*",
    url_matcher_type TEXT,
    url_pattern TEXT,
    header_matchers TEXT,
    body_matcher_type TEXT,
    body_pattern TEXT,
    action TEXT NOT NULL,
    mock_response_code INTEGER,
    mock_response_body TEXT,
    mock_response_headers TEXT,
    throttle_delay_ms INTEGER,
    throttle_delay_max_ms INTEGER,
    enabled INTEGER NOT NULL DEFAULT 1,
    created_at INTEGER NOT NULL
);

-- NetworkLog queries
insertNetworkLog:
INSERT INTO NetworkLogEntity (url, method, request_headers, request_body, response_code, response_headers, response_body, duration_ms, source, timestamp, matched_rule_id, protocol, remote_address, tls_protocol, cipher_suite, certificate_cn, issuer_cn, certificate_expiry)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

lastInsertRowId:
SELECT last_insert_rowid();

updateNetworkLog:
UPDATE NetworkLogEntity SET
    response_code = ?,
    response_headers = ?,
    response_body = ?,
    duration_ms = ?,
    source = ?,
    matched_rule_id = ?,
    protocol = ?,
    remote_address = ?,
    tls_protocol = ?,
    cipher_suite = ?,
    certificate_cn = ?,
    issuer_cn = ?,
    certificate_expiry = ?
WHERE id = ?;

getAllNetworkLogs:
SELECT * FROM NetworkLogEntity ORDER BY timestamp DESC;

getNetworkLogById:
SELECT * FROM NetworkLogEntity WHERE id = ?;

deleteAllNetworkLogs:
DELETE FROM NetworkLogEntity;

deleteNetworkLogById:
DELETE FROM NetworkLogEntity WHERE id = ?;

deleteNetworkLogsOlderThan:
DELETE FROM NetworkLogEntity WHERE timestamp < ?;

getNetworkLogsPage:
SELECT * FROM NetworkLogEntity
WHERE (url LIKE '%' || :query || '%'
   OR method LIKE '%' || :query || '%'
   OR CAST(response_code AS TEXT) LIKE '%' || :query || '%')
AND (:afterId IS NULL OR id < :afterId)
ORDER BY id DESC
LIMIT :limit;

-- Rule queries
insertRule:
INSERT INTO RuleEntity (method, url_matcher_type, url_pattern, header_matchers, body_matcher_type, body_pattern, action, mock_response_code, mock_response_body, mock_response_headers, throttle_delay_ms, throttle_delay_max_ms, enabled, created_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getAllRules:
SELECT * FROM RuleEntity ORDER BY created_at DESC;

getRuleById:
SELECT * FROM RuleEntity WHERE id = ?;

getEnabledRules:
SELECT * FROM RuleEntity WHERE enabled = 1 ORDER BY created_at DESC;

updateRuleEnabled:
UPDATE RuleEntity SET enabled = ? WHERE id = ?;

updateRule:
UPDATE RuleEntity SET method = ?, url_matcher_type = ?, url_pattern = ?, header_matchers = ?,
    body_matcher_type = ?, body_pattern = ?, action = ?,
    mock_response_code = ?, mock_response_body = ?, mock_response_headers = ?,
    throttle_delay_ms = ?, throttle_delay_max_ms = ?, enabled = ?
WHERE id = ?;

searchRules:
SELECT * FROM RuleEntity
WHERE (url_pattern LIKE '%' || :query || '%'
   OR body_pattern LIKE '%' || :query || '%'
   OR header_matchers LIKE '%' || :query || '%'
   OR method LIKE '%' || :query || '%'
   OR action LIKE '%' || :query || '%')
ORDER BY created_at DESC;

deleteRuleById:
DELETE FROM RuleEntity WHERE id = ?;

deleteAllRules:
DELETE FROM RuleEntity;

-- Socket tables

CREATE TABLE IF NOT EXISTS SocketLogEntity (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    url TEXT NOT NULL,
    request_headers TEXT NOT NULL DEFAULT "",
    status TEXT NOT NULL DEFAULT "Connecting",
    close_code INTEGER,
    close_reason TEXT,
    failure_message TEXT,
    message_count INTEGER NOT NULL DEFAULT 0,
    timestamp INTEGER NOT NULL,
    closed_at INTEGER,
    protocol TEXT,
    remote_address TEXT,
    history_cleared INTEGER NOT NULL DEFAULT 0
);

CREATE TABLE IF NOT EXISTS SocketMessageEntity (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    socket_id INTEGER NOT NULL,
    direction TEXT NOT NULL,
    content_type TEXT NOT NULL,
    content TEXT NOT NULL,
    byte_count INTEGER NOT NULL,
    timestamp INTEGER NOT NULL,
    FOREIGN KEY (socket_id) REFERENCES SocketLogEntity(id) ON DELETE CASCADE
);

-- SocketLog queries

insertSocketLog:
INSERT INTO SocketLogEntity (url, request_headers, status, timestamp, protocol, remote_address)
VALUES (?, ?, ?, ?, ?, ?);

insertSocketLogWithId:
INSERT OR REPLACE INTO SocketLogEntity (id, url, request_headers, status, message_count, timestamp, protocol, remote_address, history_cleared)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

updateSocketLog:
UPDATE SocketLogEntity SET
    status = ?,
    close_code = ?,
    close_reason = ?,
    failure_message = ?,
    closed_at = ?,
    protocol = ?,
    remote_address = ?
WHERE id = ?;

getSocketLogById:
SELECT * FROM SocketLogEntity WHERE id = ?;

getAllSocketLogs:
SELECT * FROM SocketLogEntity ORDER BY timestamp DESC;

deleteAllSocketLogs:
DELETE FROM SocketLogEntity;

deleteClosedSocketLogs:
DELETE FROM SocketLogEntity WHERE status IN ('Closed', 'Failed');

getSocketLogsPage:
SELECT * FROM SocketLogEntity
WHERE (url LIKE '%' || :query || '%'
   OR status LIKE '%' || :query || '%')
AND (:afterId IS NULL OR id < :afterId)
ORDER BY id DESC
LIMIT :limit;

incrementSocketMessageCount:
UPDATE SocketLogEntity SET message_count = message_count + 1 WHERE id = ?;

-- SocketMessage queries

insertSocketMessage:
INSERT INTO SocketMessageEntity (socket_id, direction, content_type, content, byte_count, timestamp)
VALUES (?, ?, ?, ?, ?, ?);

getSocketMessagesBySocketId:
SELECT * FROM SocketMessageEntity WHERE socket_id = ? ORDER BY timestamp ASC;

deleteClosedSocketMessages:
DELETE FROM SocketMessageEntity WHERE socket_id IN (SELECT id FROM SocketLogEntity WHERE status IN ('Closed', 'Failed'));

deleteAllSocketMessages:
DELETE FROM SocketMessageEntity;
