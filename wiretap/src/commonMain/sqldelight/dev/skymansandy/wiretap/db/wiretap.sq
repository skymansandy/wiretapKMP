CREATE TABLE IF NOT EXISTS NetworkLogEntity (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    url TEXT NOT NULL,
    method TEXT NOT NULL,
    request_headers TEXT NOT NULL DEFAULT "",
    request_body TEXT,
    response_code INTEGER NOT NULL,
    response_headers TEXT NOT NULL DEFAULT "",
    response_body TEXT,
    duration_ms INTEGER NOT NULL,
    source TEXT NOT NULL DEFAULT "NETWORK",
    timestamp INTEGER NOT NULL
);

CREATE TABLE IF NOT EXISTS RuleEntity (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    url_pattern TEXT NOT NULL,
    method TEXT NOT NULL DEFAULT "*",
    action TEXT NOT NULL,
    mock_response_code INTEGER,
    mock_response_body TEXT,
    mock_response_headers TEXT,
    throttle_delay_ms INTEGER,
    enabled INTEGER NOT NULL DEFAULT 1,
    created_at INTEGER NOT NULL
);

-- NetworkLog queries
insertNetworkLog:
INSERT INTO NetworkLogEntity (url, method, request_headers, request_body, response_code, response_headers, response_body, duration_ms, source, timestamp)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?);

getAllNetworkLogs:
SELECT * FROM NetworkLogEntity ORDER BY timestamp DESC;

getNetworkLogById:
SELECT * FROM NetworkLogEntity WHERE id = ?;

deleteAllNetworkLogs:
DELETE FROM NetworkLogEntity;

deleteNetworkLogById:
DELETE FROM NetworkLogEntity WHERE id = ?;

getNetworkLogsPage:
SELECT * FROM NetworkLogEntity
WHERE url LIKE '%' || :query || '%'
   OR method LIKE '%' || :query || '%'
   OR CAST(response_code AS TEXT) LIKE '%' || :query || '%'
ORDER BY timestamp DESC
LIMIT :limit OFFSET :offset;

getNetworkLogsCount:
SELECT COUNT(*) FROM NetworkLogEntity
WHERE url LIKE '%' || :query || '%'
   OR method LIKE '%' || :query || '%'
   OR CAST(response_code AS TEXT) LIKE '%' || :query || '%';

-- Rule queries
insertRule:
INSERT INTO RuleEntity (url_pattern, method, action, mock_response_code, mock_response_body, mock_response_headers, throttle_delay_ms, enabled, created_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

getAllRules:
SELECT * FROM RuleEntity ORDER BY created_at DESC;

getRuleById:
SELECT * FROM RuleEntity WHERE id = ?;

getEnabledRules:
SELECT * FROM RuleEntity WHERE enabled = 1 ORDER BY created_at DESC;

updateRuleEnabled:
UPDATE RuleEntity SET enabled = ? WHERE id = ?;

deleteRuleById:
DELETE FROM RuleEntity WHERE id = ?;

deleteAllRules:
DELETE FROM RuleEntity;
