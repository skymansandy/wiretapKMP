CREATE TABLE IF NOT EXISTS CollectionFolder (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    parent_id INTEGER,
    created_at INTEGER NOT NULL
);

CREATE TABLE IF NOT EXISTS SavedRequest (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    folder_id INTEGER,
    url TEXT NOT NULL,
    method TEXT NOT NULL,
    headers TEXT NOT NULL,
    params TEXT NOT NULL,
    body TEXT NOT NULL,
    created_at INTEGER NOT NULL
);

-- Folder queries

insertFolder:
INSERT INTO CollectionFolder (name, parent_id, created_at) VALUES (:name, :parent_id, :created_at);

lastInsertedRowId:
SELECT last_insert_rowid();

getFoldersByParent:
SELECT * FROM CollectionFolder WHERE parent_id IS :parent_id ORDER BY name;

getAllFolders:
SELECT * FROM CollectionFolder ORDER BY name;

getFolderById:
SELECT * FROM CollectionFolder WHERE id = :id;

deleteFolder:
DELETE FROM CollectionFolder WHERE id = :id;

-- Request queries

insertRequest:
INSERT INTO SavedRequest (name, folder_id, url, method, headers, params, body, created_at)
VALUES (:name, :folder_id, :url, :method, :headers, :params, :body, :created_at);

getRequestsByFolder:
SELECT * FROM SavedRequest WHERE folder_id IS :folder_id ORDER BY name;

getAllRequests:
SELECT * FROM SavedRequest ORDER BY name;

getRequestById:
SELECT * FROM SavedRequest WHERE id = :id;

moveFolderToParent:
UPDATE CollectionFolder SET parent_id = :parent_id WHERE id = :id;

moveRequestToFolder:
UPDATE SavedRequest SET folder_id = :folder_id WHERE id = :id;

updateRequest:
UPDATE SavedRequest
SET name = :name, folder_id = :folder_id, url = :url, method = :method,
    headers = :headers, params = :params, body = :body, created_at = :created_at
WHERE id = :id;

deleteRequest:
DELETE FROM SavedRequest WHERE id = :id;